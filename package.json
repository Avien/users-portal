{
  "name": "@users-portal/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "start:angular": "nx serve users-portal-angular",
    "start:react": "nx serve users-portal-react --port=4201",
    "start:shell": "npx serve apps/portal-shell --listen 4000",
    "mock:ws": "node tools/mock-orders-ws-server.mjs",
    "validate": "npm run lint && npm run test",
    "validate:angular": "nx run-many -t lint test --projects=tag:framework:angular,tag:framework:shared",
    "validate:react": "tsc --noEmit -p apps/users-portal-react/tsconfig.app.json && nx run-many -t lint test --projects=tag:framework:react,tag:framework:shared",
    "build:angular": "npm run validate:angular && nx build users-portal-angular",
    "build:react": "npm run validate:react && nx build users-portal-react",
    "build:prod": "npm run build:angular"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "~21.1.0",
    "@angular/common": "~21.1.0",
    "@angular/compiler": "~21.1.0",
    "@angular/core": "~21.1.0",
    "@angular/forms": "~21.1.0",
    "@angular/platform-browser": "~21.1.0",
    "@angular/platform-browser-dynamic": "~21.1.0",
    "@angular/router": "~21.1.0",
    "@module-federation/runtime": "^2.4.0",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/entity": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.0",
    "rxjs": "~7.8.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.1.0",
    "@angular-devkit/schematics": "~21.1.0",
    "@angular/build": "~21.1.0",
    "@angular/cli": "~21.1.0",
    "@angular/compiler-cli": "~21.1.0",
    "@angular/language-service": "~21.1.0",
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@eslint/js": "^9.8.0",
    "@module-federation/vite": "^1.15.5",
    "@nx/angular": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/react": "^22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@schematics/angular": "~21.1.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.0",
    "angular-eslint": "^21.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.1.8",
